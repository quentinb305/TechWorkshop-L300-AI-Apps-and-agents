graph TD
    subgraph Browser["🌐 Browser"]
        WS_Client["WebSocket Client<br/>(chat.html)"]
    end

    subgraph ChatApp["⚡ chat_app.py — Central Orchestrator"]
        WSHandler["WebSocket Handler<br/>/ws endpoint"]
        SessionState["Session State<br/>chat_history · persistent_cart<br/>image_cache · raw_io_history<br/>session_discount · bad_prompts"]
        MsgLoop["8-Step Message Loop<br/>parse → history → classify →<br/>enrich → execute → parse →<br/>update state → send"]
        BGTask["Background Task<br/>Customer Loyalty"]
    end

    subgraph Services["🔧 Services"]
        HS["handoff_service.py<br/>Intent Classification<br/>IntentClassification (Pydantic)<br/>5 domains · sticky routing"]
